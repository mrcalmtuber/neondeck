# =============================================================================
# NeonDeck Windows Daemon — environment template
# -----------------------------------------------------------------------------
# Copy this file to ".env" (same folder) and fill in real values. The daemon
# loads the nearest .env automatically at startup (Node's built-in env loader,
# requires Node >= 20.12). Every secret here stays on the host — none are ever
# sent to the browser.
#
# Windows note: use plain forward-slash or escaped paths for IDE_PROJECTS_ROOT,
# e.g.  IDE_PROJECTS_ROOT=C:/Users/you/neondeck-projects
# =============================================================================

# ---- AI provider (DeepSeek-compatible; daemon-only, white-labeled) ----------
# The browser AI sidebar calls the daemon; the daemon attaches THIS key. The
# AGENT_* names are preferred; the legacy DEEPSEEK_* names still work.
AGENT_API_KEY=
AGENT_BASE_URL=https://api.deepseek.com/v1
AGENT_MODEL=deepseek-v4-flash

# ---- Daemon network ---------------------------------------------------------
# Bind interface + port for the WebSocket bridge AND the HTTP /api routes.
# Use 127.0.0.1 for loopback-only local dev; 0.0.0.0 to expose on the LAN.
IDE_DAEMON_HOST=127.0.0.1
IDE_DAEMON_PORT=5000
# Host gateway port that fronts dynamic container/app preview slots.
IDE_PROXY_PORT=9000
# Where the user's projects live (each subfolder is a project workspace).
# Defaults to <home>/ide-projects when unset.
IDE_PROJECTS_ROOT=

# ---- CORS / WebSocket origins ----------------------------------------------
# Comma-separated list of web origins allowed to connect (your frontend URL).
IDE_ALLOWED_ORIGINS=http://localhost:5173
# Set to 1 to reflect ANY origin (dev only — never on a public node).
IDE_ALLOW_ALL_ORIGINS=
# Where Stripe Checkout returns the user (defaults to http://localhost:5173).
IDE_APP_ORIGIN=http://localhost:5173

# ---- Code-execution runtime -------------------------------------------------
# Container image used when Docker is available (LOCAL_NODE host exec otherwise).
IDE_IMAGE=node:20-alpine
# Tier granted to the local dev user when Firebase auth is NOT configured
# (0|1|2 or free|pro|max). Defaults to 2 (Max) so local dev is unrestricted.
IDE_DEV_TIER=2

# ---- Auth: Firebase ---------------------------------------------------------
# When set, the daemon verifies real Firebase ID tokens against Google's public
# certs (no service-account secret needed). Leave blank to fall back to a local
# "dev" user.
FIREBASE_PROJECT_ID=

# ---- Billing: Stripe --------------------------------------------------------
# Provide real test-mode keys to drive genuine Stripe Checkout + webhooks.
# When STRIPE_SECRET_KEY is unset, a mock Stripe is used (simulated upgrades,
# no charge, never blocks the UI).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_MAX=
# Forward webhooks to the daemon while developing (with live keys):
#   stripe listen --forward-to localhost:5000/api/webhooks/stripe
