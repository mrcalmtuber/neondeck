# ===========================================================================
# NeonDeck platform environment. Copy to `.env` (gitignored) and fill in.
# Secrets here stay on the DAEMON / build host. The browser's Firebase config is
# PUBLIC by design and is hardcoded in web/src/lib/firebaseClient.ts (Firebase
# web keys identify the project; Security Rules + Auth protect the data).
# ===========================================================================

# ---- NeonDeck agent provider (daemon-only; white-labeled in the UI) ----
# The browser AI sidebar calls the daemon; the daemon attaches THIS key and
# routes to the provider. End users never supply a key. AGENT_* are the neutral
# names; the legacy DEEPSEEK_* names still work as a fallback.
DEEPSEEK_API_KEY=
# AGENT_API_KEY=
# NOTE: "deepseek-v4-flash" is the spec's literal id and is the built-in default,
# but it is NOT a model the real DeepSeek API serves — live calls will 400 until
# you set a valid model below (e.g. deepseek-chat or deepseek-reasoner).
# AGENT_MODEL=deepseek-chat
# AGENT_BASE_URL=https://api.deepseek.com/v1

# ---- Daemon network (headless / self-hosted production) ----
# Bind host/port for the WS + HTTP API. Defaults: 0.0.0.0 : 5050 so external
# users can reach the node. Use 127.0.0.1 for loopback-only local dev.
# IDE_DAEMON_HOST=0.0.0.0
# IDE_DAEMON_PORT=5050
# Origins allowed to connect (comma-separated). Add your production web domain.
# IDE_ALLOWED_ORIGINS=https://app.neondeck.io
# Reflect ANY origin (disables the allow-list). Opt-in; never enable on an
# internet-facing node without Firebase auth + a firewall.
# IDE_ALLOW_ALL_ORIGINS=0

# ---- Browser → daemon endpoint (build-time, web only) ----
# Point the web app at a remote NeonDeck node. Default ws://127.0.0.1:5050.
# VITE_DAEMON_URL=wss://node.neondeck.io

# ---- Auth: Firebase (daemon verifies ID tokens against Google's public certs) ----
# The project id is PUBLIC; no service-account secret is needed for verification.
# Defaults to the live NeonDeck project. Set to "" to force local "dev" mode.
# FIREBASE_PROJECT_ID=neondeck-production
# Tier granted to the local "dev" user when Firebase is NOT configured (0|1|2 or free|pro|max)
IDE_DEV_TIER=max
# LOCAL DEV ONLY: grant the local "dev" user to token-less LOOPBACK connections
# (so daemon mode works with no sign-in — handy in Safari where Google is blocked).
# Only takes effect when the daemon is bound to a loopback host (run with
# `--host 127.0.0.1`) and there is no reverse proxy. NEVER set this on a public
# node or behind a proxy — it would grant dev access to everyone. Off by default.
# IDE_TRUST_LOOPBACK=1

# ---- Auth: Firebase (browser client config is hardcoded, public by design) ----
# Override a single field at build time if pointing at a staging project:
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=

# ---- Billing: Stripe (OPTIONAL — a mock Stripe is used when unset) ----
# Billing is always treated as "configured" so it never blocks the workspace.
# Without these keys, upgrades are simulated in the local ledger (no charge).
# Provide real test-mode keys to drive genuine Stripe Checkout instead.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO=price_...     # Pro price id
# STRIPE_PRICE_MAX=price_...     # Max price id

# Where Stripe Checkout returns the user (defaults to http://localhost:5173)
IDE_APP_ORIGIN=http://localhost:5173

# Forward webhooks to the daemon while developing (only with live Stripe keys):
#   stripe listen --forward-to localhost:5000/api/webhooks/stripe

# ---- GitHub OAuth: per-user project sync (OPTIONAL — off when unset) ----
# Lets each user "Connect GitHub" and have THEIR projects synced to THEIR own
# private `neondeck-projects` repo (so they survive a diskless redeploy). Create a
# GitHub OAuth App (Settings → Developer settings → OAuth Apps); callback URL
# http://localhost:5050/api/github/callback (dev) / https://<app>/api/github/callback
# (prod). The secret is daemon-only; the token is held in the user's browser.
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
