rules_version = '2';

// NeonDeck Firestore Security Rules
// =================================
// The browser holds the project's PUBLIC web config (web/src/lib/firebaseClient.ts),
// so any signed-in user can talk to Firestore directly. These rules are the ONLY
// thing standing between one user and everyone else's data. Without them (test-mode
// / "allow if request.auth != null"), any authenticated user could read every other
// user's project snapshots and usage meters. (Report finding M1.)
//
// The daemon uses the Firebase ADMIN SDK (FIREBASE_SERVICE_ACCOUNT), which bypasses
// these rules entirely — so locking the server-only collections to `if false` for
// clients does NOT break the daemon; it just blocks the browser.
//
// DEPLOY (these rules do not take effect until published):
//   Option A — Firebase Console: Build → Firestore Database → Rules → paste → Publish.
//   Option B — CLI: `firebase deploy --only firestore:rules`
//               (needs `firebase login` + a firebase.json pointing "firestore.rules"
//                here). Verify afterward in the Rules Playground.

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- SERVER-ONLY collections (daemon Admin SDK only) ----
    // Durable per-user usage metering. Written exclusively by the daemon.
    match /neondeck_usage/{document=**} {
      allow read, write: if false;
    }
    // The free "persistent disk": project snapshot manifests + their nested
    // subcollections (v2 `blobs`, legacy `chunks`). Written exclusively by the
    // daemon. `{document=**}` covers the manifest doc AND all subcollections.
    match /neondeck_fs/{document=**} {
      allow read, write: if false;
    }
    // Developer program: waitlist/acceptance state, card-on-file, and API-key
    // HASHES. Written exclusively by the daemon.
    match /neondeck_dev/{document=**} {
      allow read, write: if false;
    }
    // API-key auth index (sha256 -> owner). Daemon-only; a client read of this
    // would leak which key hashes exist.
    match /neondeck_dev_keys/{document=**} {
      allow read, write: if false;
    }

    // ---- CLIENT collections (browser, scoped to the owner) ----
    // One profile doc per account, keyed by uid. A user may only touch their own.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Project records, each owned by a uid stored on the doc. A user may only read
    // their own; creates must stamp their own uid; updates/deletes stay owner-only.
    match /projects/{projectId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ---- Everything else: deny by default ----
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
