# NeonDeck is white-labeled — the UI never names the underlying AI provider.
# These optional vars point the agent at your own model endpoint.
VITE_AGENT_BASE_URL=
VITE_AGENT_MODEL=

# Auth is Firebase. The live web config is PUBLIC by design and is hardcoded in
# web/src/lib/firebaseClient.ts, so the email/password gateway works out of the
# box. Override any single field below to point a build at a different project.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: point the browser at a remote NeonDeck daemon node. The pricing page
# POSTs to this daemon's /api/create-checkout-session (Bearer Firebase ID token)
# and redirects to the hosted Stripe Checkout url it returns.
VITE_DAEMON_URL=

# Billing is handled entirely by the daemon's own Stripe integration (no Firebase
# Blaze "Run Payments with Stripe" extension). The Stripe secret/webhook keys and
# the Pro/Max price IDs live in the DAEMON env (STRIPE_SECRET_KEY,
# STRIPE_WEBHOOK_SECRET, STRIPE_PRICE_PRO, STRIPE_PRICE_MAX) — never in the
# browser bundle. When the daemon isn't connected, the Billing tab simulates
# upgrades locally (no charge) so it never dead-ends.
